{
  "name": "semedit",
  "version": "0.1.0",
  "description": "Online editor for RDF and SKOS files",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "server": "node server/index.js",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm server\""
  },
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "n3": "^2.0.3",
    "neo4j-driver": "^6.0.1",
    "openspec": "latest",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/n3": "^1.26.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
